pipeline {
    agent any

    stages {
        stage('Deployment') {
            steps {
                sh '''
scp -o StrictHostKeyChecking=no docker-compose.yaml ubuntu@52.66.103.98:/home/ubuntu/
    
ssh -o StrictHostKeyChecking=no ubuntu@52.66.103.98 << EOF
cd /home/ubuntu
docker-compose down
docker-compose up -d
EOF
'''
            }
        }
    }
}
pipeline {
    agent any

    stages {
        stage('Deployment') {
            steps {
                sh '''
                scp -o StrictHostKeyChecking=no docker-compose.yml ubuntu@13.203.201.251:/home/ubuntu/docker-compose.yml

                ssh -o StrictHostKeyChecking=no ubuntu@13.203.201.251 '
                    docker compose -f /home/ubuntu/docker-compose.yml down
                    docker compose -f /home/ubuntu/docker-compose.yml up -d
                '
                '''
            }
        }
    }
}
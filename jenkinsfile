pipeline {
    agent any

    stages {
        stage('Deployment') {
            steps {
                sh '''
scp -o StrictHostKeyChecking=no docker-compose.yaml ubuntu@3.108.55.236:/home/ubuntu/
    
ssh -o StrictHostKeyChecking=no ubuntu@3.108.55.236 << EOF
cd /home/ubuntu
docker-compose down
docker-compose up -d
EOF
'''
            }
        }
    }
}
pipeline {
    agent { label 'Frontend' }

    environment {
        APP_SERVER = "172.31.42.10"
        DEPLOY_DIR = "/var/www/html"
    }

    stages {

        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }

        stage('Build') {
            steps {
                sh 'npm run build'
            }
        }

        stage('Deploy') {
            steps {
                sh """

                ssh-keyscan -H ${APP_SERVER} >> ~/.ssh/known_hosts

                ssh jenkins@${APP_SERVER} "mkdir -p /tmp/frontend"

                scp -r dist/* jenkins@${APP_SERVER}:/tmp/frontend/

                ssh jenkins@${APP_SERVER} "

                    sudo rm -rf ${DEPLOY_DIR}/*

                    sudo cp -r /tmp/frontend/* ${DEPLOY_DIR}/

                    sudo systemctl restart nginx

                    rm -rf /tmp/frontend/*
                "

                """
            }
        }
    }
}